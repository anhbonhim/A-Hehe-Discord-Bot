# Discord Bot Token (bắt buộc)
# Lấy từ: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# OpenRouter API Key (bắt buộc)
# Lấy từ: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model AI (tuỳ chọn, mặc định: openai/gpt-oss-120b)
AI_MODEL=openai/gpt-oss-120b

# Mức độ suy luận: auto, low, medium, high (tuỳ chọn, mặc định: auto)
# auto = model tự quyết định, có thể đổi bằng lệnh /model reasoning:<mức>
REASONING_EFFORT=auto

# Tavily API Key cho tìm kiếm web (tuỳ chọn)
# Lấy từ: https://tavily.com
# Nếu không có, DuckDuckGo sẽ được dùng thay thế
TAVILY_API_KEY=

# Tiền tố lệnh bot (tuỳ chọn, mặc định: !ai)
BOT_PREFIX=!ai

# Discord Application/Client ID (bắt buộc cho slash commands)
CLIENT_ID=your_client_id_here

# Google Gemini API Key (tuỳ chọn, bắt buộc nếu muốn nhận diện hình ảnh độ chính xác cao)
# Lấy từ: https://aistudio.google.com
GEMINI_API_KEY=

